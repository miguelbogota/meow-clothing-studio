{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "meow-clothing-studio-marketplace": {
      "development": {
        "local": 3000,
        "fallback": "meow-clothing-studio-marketplace.vercel.app"
      }
    },
    "meow-clothing-studio-checkout": {
      "development": {
        "local": 3001,
        "fallback": "meow-clothing-studio-checkout.vercel.app"
      },
      "routing": [
        {
          "group": "checkout",
          "paths": ["/checkout"]
        }
      ]
    }
  }
}
